-- Structure principale de la base de données SMMC

-- Table des utilisateurs
CREATE TABLE utilisateurs (
    idUtilisateur INT PRIMARY KEY AUTO_INCREMENT,
    matricule VARCHAR(20) UNIQUE NOT NULL,
    nom VARCHAR(100) NOT NULL,
    prenom VARCHAR(100) NOT NULL,
    motDePasse VARCHAR(255) NOT NULL,
    role ENUM('admin', 'responsable', 'agent', 'technicien') NOT NULL,
    email VARCHAR(255) UNIQUE,
    telephone VARCHAR(20),
    actif BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- Table des caméras
CREATE TABLE cameras (
    idCamera INT PRIMARY KEY AUTO_INCREMENT,
    numeroSerie VARCHAR(50) UNIQUE NOT NULL,
    adresseIP VARCHAR(15) NOT NULL,
    zone VARCHAR(100) NOT NULL,
    emplacement VARCHAR(255) NOT NULL,
    statut ENUM('actif', 'panne', 'hors ligne') DEFAULT 'actif',
    dateInstallation DATETIME NOT NULL,
    idTechnicien INT,
    -- Champs pour la corbeille
    actif BOOLEAN DEFAULT TRUE,
    deleted_at TIMESTAMP NULL,
    deleted_by INT NULL,
    deletion_reason TEXT NULL,
    restored_at TIMESTAMP NULL,
    restored_by INT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (idTechnicien) REFERENCES utilisateurs(idUtilisateur),
    FOREIGN KEY (deleted_by) REFERENCES utilisateurs(idUtilisateur),
    FOREIGN KEY (restored_by) REFERENCES utilisateurs(idUtilisateur)
);

-- Table des incidents
CREATE TABLE incidents (
    idIncident INT PRIMARY KEY AUTO_INCREMENT,
    dateHeure DATETIME NOT NULL,
    typeIncident VARCHAR(100) NOT NULL,
    description TEXT NOT NULL,
    zone VARCHAR(100) NOT NULL,
    photo1 VARCHAR(255) NULL,
    photo2 VARCHAR(255) NULL,
    photo3 VARCHAR(255) NULL,
    photo4 VARCHAR(255) NULL,
    photo5 VARCHAR(255) NULL,
    photo6 VARCHAR(255) NULL,
    statut ENUM('en_attente', 'valide', 'rejete') DEFAULT 'en_attente',
    idCamera INT,
    idUtilisateur INT NOT NULL,
    validePar INT NULL,
    dateValidation DATETIME NULL,
    commentaireValidation TEXT NULL,
    -- Champs pour la corbeille
    actif BOOLEAN DEFAULT TRUE,
    deleted_at TIMESTAMP NULL,
    deleted_by INT NULL,
    deletion_reason TEXT NULL,
    restored_at TIMESTAMP NULL,
    restored_by INT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (idCamera) REFERENCES cameras(idCamera),
    FOREIGN KEY (idUtilisateur) REFERENCES utilisateurs(idUtilisateur),
    FOREIGN KEY (validePar) REFERENCES utilisateurs(idUtilisateur),
    FOREIGN KEY (deleted_by) REFERENCES utilisateurs(idUtilisateur),
    FOREIGN KEY (restored_by) REFERENCES utilisateurs(idUtilisateur)
);